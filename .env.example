# Application
APP_ENV=local
DATABASE_URL=sqlite:///./data/fraud_platform.db
LOG_LEVEL=INFO

# Fraud thresholds (tunable)
HIGH_VALUE_THRESHOLD_USD=10000
RAPID_TRANSFER_WINDOW_MINUTES=30
RAPID_TRANSFER_MIN_COUNT=5
MULE_INBOUND_MIN_SOURCES=4
MULE_OUTBOUND_HOURS=24
VELOCITY_SPIKE_MULTIPLIER=3.0

# Phase 2 — GCP (leave empty for local-only)
GCP_PROJECT_ID=
BIGQUERY_DATASET_ID=fraud_investigation
BIGQUERY_LOCATION=US
GCS_BUCKET_NAME=
USE_BIGQUERY=false

# Gemini (Agent B — Compliance Report / Gemini API)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ADK multi-agent orchestration (Option 1)
USE_ADK=true
AUTO_SYNC_BIGQUERY=false

# Cloud Run
PORT=8080
